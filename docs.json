{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Zupy Partner API",
  "colors": {
    "primary": "#6366F1",
    "light": "#8B5CF6",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "index",
              "authentication"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/getting-started",
              "guides/webhook-setup",
              "guides/otp-flow",
              "guides/partner-onboarding"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Support",
          "href": "mailto:webmaster@zupy.com.br",
          "icon": "envelope"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/zupy-fmartinelli",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.zupy.com"
      },
      {
        "label": "Support",
